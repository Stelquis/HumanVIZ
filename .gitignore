# ========================================
# Git 忽略规则配置
# ========================================

# ========================================
# 构建 / 运行时产物
# ========================================

# Python 字节码缓存（自动生成）
__pycache__/
*.py[cod]

# Vite / 前端构建输出
dist/

# Node.js 依赖包目录
node_modules/

# ========================================
# 数据库文件
# ========================================

# SQLite 数据库（二进制大文件，频繁修改）
*.db

# ========================================
# 敏感配置
# ========================================

# API 密钥配置文件
secrets.json

# 环境变量文件
.env

# ========================================
# LaTeX 编译中间文件（XeLaTeX / pdfLaTeX）
# ========================================

# 辅助文件（跨次编译引用、目录、交叉引用等）
*.aux
*.out
*.toc
*.log

# ========================================
# 日志和运行时文件
# ========================================

# 日志文件
*.log

# 进程 PID 文件
.pids
*.pid

# ========================================
# Skills / Agent 自动生成目录
# ========================================

# Agent 框架 skill 定义（由 init-claude.sh / init-codex.sh 自动生成）
.agents/
.codebuddy/skills/
.claude/
