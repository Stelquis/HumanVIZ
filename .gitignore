# ========================================
# HumanViz - Git 忽略规则配置
# ========================================

# ========================================
# 1. 依赖包目录
# ========================================

# Node.js 依赖包目录（由 yarn install 或 npm install 生成）
# 包含所有前端项目所需的第三方库和工具
node_modules/

# Python 虚拟环境
# 包含 Python 虚拟环境的所有文件
.venv/
venv/
ENV/

# Python 虚拟环境锁定文件（由 pipenv install 生成）
# 包含精确的依赖包版本信息，不建议提交到代码仓库
# 因为不同开发环境可能需要不同的依赖版本
Pipfile.lock

# ========================================
# 2. 系统和缓存文件
# ========================================

# Python 字节码缓存目录
# 包含 .pyc 文件，是 Python 运行时自动生成的
# 应该被忽略，让每个开发者环境独立生成
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# ========================================
# 3. 构建产物和输出文件
# ========================================

# Vite 前端构建输出目录（由 yarn build 生成）
# 包含打包、压缩后的生产环境代码
# 应该忽略，每个部署时独立构建
dist/

# 归档文件目录
# 用于存储旧版本的文件或备份数据
archive/

# ========================================
# 4. 敏感配置文件
# ========================================

# 私人数据目录（仅根目录）
# 包含用户私人数据，不应公开
# /scripts/

# API 密钥配置文件
# 包含 OpenAI、Google、智谱等平台的 API 密钥
# 绝对不能提交到代码仓库，防止密钥泄露
secrets.json

# 环境变量配置文件
# 包含敏感的环境配置信息，如数据库连接字符串等
.env
.env.local
.env.*.local

# ========================================
# 5. 日志和运行时文件
# ========================================

# 日志文件
# 包含应用程序运行时生成的日志
*.log
logs/
log/

# 进程 PID 文件
# 用于记录正在运行的服务进程 ID
.pids
*.pid
*.pid.lock

# ========================================
# 6. IDE 和编辑器配置
# ========================================

# VS Code 配置
# 包含个人化的编辑器设置
.vscode/
*.code-workspace

# JetBrains IDE (PyCharm, WebStorm, etc.)
.idea/
*.iml

# Vim 交换文件
*.swp
*.swo
*~

# Sublime Text
*.sublime-project
*.sublime-workspace

# ========================================
# 7. 测试和临时文件
# ========================================

# 测试文件或临时测试目录
# 避免提交临时的测试代码和数据
test/
tests/
*.test.js
*.test.ts
*.test.tsx
coverage/

# 临时文件
tmp/
temp/
*.tmp

# ========================================
# 8. Jupyter 数据处理中间文件
# ========================================

# Jupyter Notebook 检查点
# 自动保存的 notebook 版本
.ipynb_checkpoints/

# # 数据处理脚本目录
# # 包含用于数据处理的临时脚本
# scripts/

# JSON 中间数据文件目录
# 包含数据解析过程中的中间 JSON 文件
json/

# CSV 中间数据文件目录
# 包含数据导出的 CSV 文件
csv/

# 解析后的章节文本目录
# 包含从原始文本分割出的章节文件
notebooks/chapters/

# 引用文本数据目录
# 包含从故事中提取的引用文本
notebooks/quotes/

# ========================================
# 9. 数据库文件
# ========================================

# SQLite 数据库文件
# 二进制大文件，频繁修改，不应提交到仓库
*.db
*.db-journal
*.sqlite
*.sqlite3

# 数据处理结果文件
# 由脚本自动生成的分类/处理结果，不需要版本控制
classification_results/
dialogue_parsing_results/

# ========================================
# 10. 前端工具缓存
# ========================================

# ESLint 缓存
.eslintcache

# Vite 缓存
.vite/

# TypeScript 缓存
*.tsbuildinfo

# Yarn 缓存
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*