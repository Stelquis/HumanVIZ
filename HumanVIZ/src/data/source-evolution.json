  "sourceMeta": {
    "民国汇编本": {
      "yearStart": 1915,
      "yearEnd": 1949,
      "shortLabel": "民国汇编",
      "desc": "《戏考》《国剧大成》等民国时期剧本汇编",
      "note": "京剧文本化的第一个高峰期",
      "eraContext": "民国时期京剧文本化运动兴起，以《戏考》《国剧大成》为代表的大规模剧本汇编集中保存了大量以生行（老生）为主的袍带戏和公案戏，老生行当在这一时期占据绝对主导地位，净行花脸角色（曹操、张飞、包拯等）也因忠奸分明的叙事传统而占有重要份额"
    },
    "新中国整理本": {
      "yearStart": 1950,
      "yearEnd": 1999,
      "shortLabel": "新中国整理",
      "desc": "《京剧汇编》《京剧丛刊》等新中国系统性整理",
      "note": "国家主导的剧本标准化整理工程",
      "eraContext": "新中国成立后，国家主导的《京剧汇编》《京剧丛刊》等标准化整理项目对传统剧目进行了系统性筛选和改编，去芜存菁的同时也强化了以正面男性角色为核心的故事模式，生行占比进一步提升，旦行和丑行则更多服务于家庭伦理和民间生活题材"
    },
    "名家演出本": {
      "yearStart": 1920,
      "yearEnd": 1990,
      "shortLabel": "名家演出",
      "desc": "梅兰芳、周信芳、马连良、程砚秋等名家剧本选",
      "note": "以名角为中心的流派剧本传承",
      "eraContext": "以梅兰芳、周信芳、马连良等名角为中心的流派传承体系下，演出本保留了各流派代表剧目的行当分配格局，生行在三国戏、公案戏中占据叙事中心，旦行则因为梅派、程派等旦角流派拥有大量代表剧目而获得突出地位"
    },
    "昆曲剧本选": {
      "yearStart": 1950,
      "yearEnd": 2000,
      "shortLabel": "昆曲传承",
      "desc": "侯玉山、俞振飞等昆曲大师传承剧本",
      "note": "昆曲剧目文本化保存，唱腔占比仅0.5%",
      "eraContext": "昆曲剧目文本化保存项目以记录口传心授的经典折子戏为主，生行（巾生、官生）在《牡丹亭》《长生殿》等才子佳人戏中占据叙事焦点，而武戏和花脸的占比相对较低，反映了昆曲以文戏为主的艺术传统"
    },
    "录音藏本及其他": {
      "yearStart": 1930,
      "yearEnd": 2000,
      "shortLabel": "录音藏本",
      "desc": "唱片录音本、院团改编演出本、名家藏本",
      "note": "多样来源的补充性文献",
      "eraContext": "唱片录音本、院团改编演出本和名家藏本等多样化来源反映了京剧演出市场的丰富生态，这些文献以当时舞台常演剧目为主，丑行在诙谐戏和市井题材中占比突出，旦行则因市场化演出中对女性角色需求的增加而稳步上升"
    },
    "现代剧作家本": {
      "yearStart": 1950,
      "yearEnd": 1980,
      "shortLabel": "现代创作",
      "desc": "田汉、老舍、翁偶虹、范钧宏等剧作家创作",
      "note": "现当代京剧文学创作，角色规模最大（平均38角色/本）",
      "eraContext": "田汉、老舍、翁偶虹等剧作家独立创作的京剧现代戏和新编历史剧，角色规模最大（平均38角色/本），打破了传统行当的固化分配模式，丑行（喜剧角色）在多元化叙事中的地位显著提升，旦行也因女性角色独立性的增强而保持了稳定的存在感"
    }
